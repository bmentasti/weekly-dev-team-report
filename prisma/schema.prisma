// Weekly Dev Team Report — Prisma schema
// Full data model per the MVP spec. Sprint 1 uses User, Workspace and
// WorkspaceMember; the remaining models are defined up front so future
// sprints (Jira, GitHub, report generation, delivery) plug in cleanly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  TECH_LEAD
  PRODUCT_OWNER
  ENGINEERING_MANAGER
  CTO
  DEVELOPER_LEAD
  DEVELOPER
  OTHER
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum IntegrationType {
  JIRA
  GITHUB
  SLACK
  LINEAR
  GITLAB
  BITBUCKET
  AZURE_DEVOPS
  CLICKUP
  NOTION
  MS_TEAMS
  AIRTABLE
  DISCORD
  OPENAI
  ANTHROPIC
  GEMINI
  COPILOT
  // Project Planning & Portfolio
  MS_PROJECT
  MS_PLANNER
  AZURE_BOARDS
  MONDAY
  ASANA
  SMARTSHEET
  WRIKE
  TEAMWORK
  BASECAMP
  TRELLO
  SHORTCUT
  ZOHO_PROJECTS
  PRIMAVERA
  JIRA_ALIGN
  JIRA_ROADMAPS
}

enum IntegrationStatus {
  // Estados de conexión / sincronización. Los tres originales (CONNECTED,
  // DISCONNECTED, ERROR) se conservan por retro-compatibilidad; el resto refleja
  // la salud REAL de la integración (no solo el resultado de la autenticación).
  NOT_CONNECTED
  CONNECTING
  CONNECTED
  SYNCING
  PARTIALLY_SYNCED
  PERMISSION_REQUIRED
  TOKEN_EXPIRED
  RATE_LIMITED
  FAILED
  DISCONNECTED
  ERROR
}

enum ReportFrequency {
  MANUAL
  WEEKLY
}

enum ReportStatus {
  DRAFT
  GENERATED
  SENT
  ERROR
}

enum HealthStatus {
  HEALTHY
  MEDIUM_RISK
  HIGH_RISK
}

enum DeliveryChannel {
  EMAIL
  SLACK
}

enum DeliveryStatus {
  PENDING
  SENT
  ERROR
}

enum PlanTier {
  FREE
  TEAM
  PRO
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
}

// ---------------------------------------------------------------------------
// Core (Sprint 1)
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  company      String?
  role         UserRole @default(OTHER)
  /// Backoffice: acceso total al panel /admin (ver/editar usuarios y planes).
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedWorkspaces   Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers  WorkspaceMember[]
  reportNotes       ReportNote[]      @relation("UserNotes")
  reportShares      ReportShare[]     @relation("UserShares")
  notifications     Notification[]    @relation("UserNotifications")
  projectMembers    ProjectMember[]   @relation("UserProjectMembers")
  passwordResets    PasswordResetToken[]
}

/// Tokens de recuperación de contraseña. Se guarda el HASH del token (nunca el
/// token en claro); expiran a la hora y son de un solo uso.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Workspace {
  id            String        @id @default(cuid())
  name          String
  companyName   String?
  teamName      String?
  teamSize      Int?
  ownerId       String
  plan          PlanTier      @default(FREE)
  billingPeriod BillingPeriod @default(MONTHLY)
  /// Backoffice: si está seteado, reemplaza el cap de reportes/mes del plan.
  reportQuotaOverride Int?
  // Reverse trial: mientras trialEndsAt sea futuro, el workspace tiene Pro.
  trialEndsAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       WorkspaceMember[]
  integrations  Integration[]
  projects      Project[]
  reportConfigs ReportConfig[]
  reports       Report[]
  healthStandards HealthStandard[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Integrations (Sprints 2 & 3)
// ---------------------------------------------------------------------------

model Integration {
  id                    String            @id @default(cuid())
  workspaceId           String
  projectId             String?
  type                  IntegrationType
  status                IntegrationStatus @default(DISCONNECTED)
  config                Json?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  // ---- Salud REAL de la sincronización (no solo autenticación) ----
  /// Última sincronización que trajo y procesó datos con éxito.
  lastSuccessfulSyncAt  DateTime?
  /// Último INTENTO de sincronización (haya salido bien o mal).
  lastSyncAttemptAt     DateTime?
  /// Cursor/updatedAt para sincronización incremental (idempotente).
  syncCursor            String?
  /// Cantidad de registros importados en el último sync exitoso.
  recordsImported       Int?
  /// Participantes vinculados a una identidad canónica.
  participantsLinked    Int?
  /// Identidades pendientes de confirmación (sugerencias sin verificar).
  pendingIdentities     Int?
  /// Actividad encontrada sin persona asociada.
  unassociatedRecords   Int?
  /// Permisos/scopes que faltan para operar (p. ej. ["repo","read:org"]).
  missingPermissions    String[]
  /// Mensaje de error comprensible para el usuario.
  lastErrorMessage      String?
  /// Acción recomendada para resolver el problema.
  recommendedAction     String?
  /// Detalle de salud: completitud, errores parciales, últimos contadores.
  healthDetail          Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([workspaceId])
  @@index([projectId])
}

model Project {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  jiraProjectKey  String?
  githubRepoOwner String?
  githubRepoName  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integrations   Integration[]
  members        ProjectMember[]
  reportConfigs  ReportConfig[]
  reports        Report[]
  personContexts PersonContext[]
  personIdentities PersonIdentity[]
  personAliases    PersonAlias[]

  // ---- Budget, Forecast & Profitability ----
  finance          ProjectFinance?
  financeBaseline  FinanceBaseline?
  forecastVersions ForecastVersion[]
  budgetChanges    BudgetChange[]
  costEntries      CostEntry[]
  revenueEntries   RevenueEntry[]
  laborRates       LaborRate[]
  milestones       FinanceMilestone[]

  @@index([workspaceId])
}

model PersonContext {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  role       String?
  seniority  String?
  daily      String? // LOW | MEDIUM | HIGH
  refinement String?
  retro      String?
  demo       String?
  ownership  String?
  feedback   String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Identidad canónica de personas (unifica identificadores cross-app)
// ---------------------------------------------------------------------------

/// Persona canónica dentro de un proyecto. `key` es el ID único y estable que
/// usan los reportes; distintos handles de apps se resuelven contra esta clave
/// vía PersonAlias, evitando duplicar a la misma persona en cada integración.
model PersonIdentity {
  id          String   @id @default(cuid())
  projectId   String
  key         String   // ID canónico (clave estable de la persona)
  displayName String
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aliases PersonAlias[]

  @@unique([projectId, key])
  @@index([projectId])
}

/// Alias que mapea un identificador de una app (o el ID de otra persona) a una
/// identidad canónica. `source` es el slug del provider o "*" para cualquiera.
model PersonAlias {
  id         String   @id @default(cuid())
  projectId  String
  identityId String
  source     String   @default("*")
  handle     String
  // ---- Identidad externa (ExternalIdentity) ----
  /// ID ESTABLE del proveedor (GitHub numeric id, Jira accountId, Airtable rec…).
  /// Una vez confirmado, se resuelve por acá y NO se re-matchea por email/nombre.
  externalUserId String?
  /// Username del proveedor (puede cambiar; por eso no es la clave estable).
  username       String?
  /// Email conocido para esta identidad externa (puede diferir del principal).
  email          String?
  /// Nombre visible en el proveedor (puede diferir entre herramientas).
  displayName    String?
  /// Cómo se estableció la asociación.
  /// email_exact | email_alias | provider_id | username | suggested | manual
  matchMethod    String   @default("manual")
  /// Confianza de la asociación (0..1).
  confidence     Float    @default(1)
  /// Si está confirmada. Las sugeridas (verified=false) NO se auto-vinculan.
  verified       Boolean  @default(true)
  verifiedAt     DateTime?
  /// Auditoría de la vinculación manual.
  createdById    String?
  createdByName  String?
  reason         String?
  createdAt      DateTime @default(now())

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  identity PersonIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([projectId, source, handle])
  @@index([projectId])
  @@index([identityId])
  @@index([projectId, externalUserId])
}

model ProjectMember {
  id        String        @id @default(cuid())
  projectId String
  userId    String
  role      WorkspaceRole @default(MEMBER)
  createdAt DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("UserProjectMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Reporting (Sprints 4 & 5)
// ---------------------------------------------------------------------------

// Parámetros de análisis / Umbrales de salud (Team & Pro).
// Un estándar por workspace (projectId = null) y, opcionalmente, overrides por proyecto.
model HealthStandard {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String? // null = estándar del workspace; con valor = override por proyecto
  name        String   @default("Estándar del workspace")
  config      Json // { thresholds: {...}, weights: {...} }
  reason      String? // motivo del último cambio (gobernanza)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, projectId])
  @@index([workspaceId])
}

// Registro de auditoría de acciones sensibles (RBAC / seguridad).
model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String?
  actorName   String?
  action      String // ej: plan.change, integration.connect, member.role, report.share
  target      String? // recurso afectado (id/nombre)
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
}

// Reglas de alerta personalizadas basadas en umbrales de métricas (Pro).
model AlertRule {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  metricKey   String
  operator    String // gt | lt | gte | lte
  threshold   Float
  severity    String   @default("medium") // high | medium | low
  enabled     Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())

  @@index([workspaceId, projectId])
}

// Historial/auditoría de cambios de estándares (Team básico, Pro completo).
model HealthStandardHistory {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  config      Json
  reason      String?
  changedById String?
  changedByName String?
  createdAt   DateTime @default(now())

  @@index([workspaceId, projectId])
}

model ReportConfig {
  id          String          @id @default(cuid())
  workspaceId String
  projectId   String?
  name        String
  frequency   ReportFrequency @default(MANUAL)
  recipients  String[]
  sections    Json?
  // Idioma de los reportes generados por el cron para este config (es/en).
  locale      String          @default("es")
  lastRunAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reports   Report[]

  @@index([workspaceId])
  @@index([projectId])
}

model Report {
  id              String       @id @default(cuid())
  workspaceId     String
  projectId       String?
  reportConfigId  String?
  periodStart     DateTime
  periodEnd       DateTime
  status          ReportStatus @default(DRAFT)
  healthStatus    HealthStatus?
  // Snapshot del score calculado con el estándar vigente al generarse (H3).
  // Congela el resultado para que editar umbrales no altere reportes pasados.
  score           Int?
  scoreLevel      String?
  standardVersion String?
  type            String       @default("SPRINT")
  pinned          Boolean      @default(false)
  reviewedAt      DateTime?
  tags            String[]
  summary         String?
  metrics         Json?
  risks           Json?
  recommendations Json?
  rawData         Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reportConfig ReportConfig?    @relation(fields: [reportConfigId], references: [id], onDelete: SetNull)
  deliveries   ReportDelivery[]
  notes        ReportNote[]
  shares       ReportShare[]

  @@index([workspaceId])
  @@index([projectId])
}

model ReportNote {
  id         String   @id @default(cuid())
  reportId   String
  authorId   String
  authorName String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  author User   @relation("UserNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([authorId])
}

model ReportShare {
  id          String    @id @default(cuid())
  reportId    String
  userId      String?
  inviteEmail String?
  // Nivel de vista compartida: EXECUTIVE (sin datos por persona) o FULL.
  level       String    @default("FULL")
  viewedAt    DateTime?
  createdAt   DateTime  @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User?  @relation("UserShares", fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  reportId  String?
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ReportDelivery {
  id           String          @id @default(cuid())
  reportId     String
  channel      DeliveryChannel
  recipient    String
  status       DeliveryStatus  @default(PENDING)
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime        @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

// ===========================================================================
// Budget, Forecast & Profitability (módulo de control financiero)
// ---------------------------------------------------------------------------
// Principio: separar ingreso / presupuesto / costo. Nunca sobrescribir la
// baseline ni el pasado (tarifas versionadas). Montos en Decimal(18,4) para
// precisión decimal segura; el servicio de cálculo redondea de forma explícita.
// ===========================================================================

enum ContractModality {
  FIXED_PRICE
  TIME_AND_MATERIALS
  MANAGED_CAPACITY
  MILESTONE_BASED
  RETAINER
  HYBRID
}

enum FinancialTrackingLevel {
  NONE
  BASIC
  FULL
}

/// Método para calcular el Earned Value (avance económico). El default combina
/// story points automáticos (Jira) con pesos manuales por entregable/milestone.
enum ProgressMethod {
  STORY_POINTS
  HOURS
  DELIVERABLE_WEIGHT
  ECONOMIC_VALUE
  MILESTONE
  CONTRACT_PERCENT
  MANUAL_WEIGHT
  WEIGHTED_COMBINATION
}

enum CostCategory {
  LABOR
  VENDOR
  LICENSE
  INFRASTRUCTURE
  TRAVEL
  EXTERNAL_SERVICE
  INDIRECT
  ADMIN
  REWORK
  BLOCKER
  PENALTY
  UNPLANNED
  OTHER
}

/// Naturaleza del costo: real registrado, comprometido (PO/contrato), forecast
/// (esperado) o potencial (estimación de riesgo). NUNCA mezclar como si fueran
/// lo mismo: el potencial no se muestra como monto real.
enum CostNature {
  ACTUAL
  COMMITTED
  FORECAST
  POTENTIAL
}

enum RevenueType {
  CONTRACTED
  INVOICED
  COLLECTED
  RECOGNIZED
  PENDING
  CHANGE_REQUEST
  BONUS
  PENALTY
}

enum FinanceChangeType {
  REESTIMATION
  BUDGET_INCREASE
  BUDGET_REDUCTION
  CHANGE_REQUEST
  SCOPE_CHANGE
  RATE_CHANGE
  TEAM_CHANGE
  DATE_CHANGE
  DATA_CORRECTION
}

enum RateScope {
  PERSON
  ROLE
  SENIORITY
  TEAM
  AVERAGE
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  DELIVERED
  ACCEPTED
  REJECTED
}

/// Configuración económica vigente del proyecto (1:1). Contiene la modalidad
/// contractual y los parámetros "current" (no la baseline inmutable).
model ProjectFinance {
  id                   String                 @id @default(cuid())
  projectId            String                 @unique
  modality             ContractModality       @default(FIXED_PRICE)
  trackingLevel        FinancialTrackingLevel @default(BASIC)
  status               String?
  // ---- Moneda / conversión ----
  currency             String                 @default("USD")
  reportingCurrency    String?
  fxRate               Decimal?               @db.Decimal(18, 6) // 1 currency = fxRate reportingCurrency
  timezone             String?
  // ---- Fechas ----
  startDate            DateTime?
  plannedEndDate       DateTime?
  contractualEndDate   DateTime?
  forecastEndDate      DateTime?
  // ---- Ingresos (contratado) ----
  contractedRevenue    Decimal?               @db.Decimal(18, 4)
  maxAuthorizedRevenue Decimal?               @db.Decimal(18, 4) // tope / cap contractual
  // ---- Presupuesto de costos ----
  originalCostBudget   Decimal?               @db.Decimal(18, 4)
  contingency          Decimal?               @db.Decimal(18, 4)
  // ---- Objetivo ----
  targetMarginPct      Decimal?               @db.Decimal(9, 4) // 0..100
  // ---- T&M / capacity ----
  maxAuthorizedHours   Decimal?               @db.Decimal(18, 4)
  contractedCapacity   Decimal?               @db.Decimal(18, 4) // FTE u horas/mes
  monthlyRevenue       Decimal?               @db.Decimal(18, 4) // retainer / managed capacity
  monthlyCost          Decimal?               @db.Decimal(18, 4)
  // ---- Avance (Earned Value) ----
  progressMethod       ProgressMethod         @default(WEIGHTED_COMBINATION)
  /// { storyPointsWeight, manualWeight, manualPct, weights:[{key,weight,pct}], ... }
  progressConfig       Json?
  workingDaysPerWeek   Int                    @default(5)
  // ---- Calendarios ----
  billingSchedule      Json?
  revenueRecognitionSchedule Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// Baseline ORIGINAL inmutable (1:1). Se captura una vez y no se sobrescribe.
model FinanceBaseline {
  id                   String   @id @default(cuid())
  projectId            String   @unique
  contractedRevenue    Decimal? @db.Decimal(18, 4)
  estimatedCost        Decimal? @db.Decimal(18, 4)
  scopeValue           Decimal? @db.Decimal(18, 4)
  estimatedHours       Decimal? @db.Decimal(18, 4)
  estimatedStoryPoints Decimal? @db.Decimal(18, 4)
  estimatedDurationDays Int?
  targetMarginPct      Decimal? @db.Decimal(9, 4)
  plannedEndDate       DateTime?
  plannedTeam          Json?
  capturedById         String?
  capturedByName       String?
  reason               String?
  createdAt            DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// Versiones del forecast (mutable, versionado). No toca la baseline.
model ForecastVersion {
  id              String   @id @default(cuid())
  projectId       String
  version         Int
  label           String?
  isCurrent       Boolean  @default(false)
  estimatedCost   Decimal? @db.Decimal(18, 4) // EAC del forecast
  projectedRevenue Decimal? @db.Decimal(18, 4)
  forecastEndDate DateTime?
  eacMethod       String?  // cost | cost_schedule | bottom_up | simple
  snapshot        Json?    // métricas congeladas al versionar
  notes           String?
  createdById     String?
  createdByName   String?
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId])
}

/// Historial de cambios financieros (ampliaciones, CRs, cambios de tarifa/fecha).
/// Cada cambio registra valor anterior/nuevo, usuario, motivo, aprobación e impacto.
model BudgetChange {
  id             String            @id @default(cuid())
  projectId      String
  type           FinanceChangeType
  field          String?
  amount         Decimal?          @db.Decimal(18, 4) // + amplía, - reduce
  previousValue  String?
  newValue       String?
  reason         String?
  approved       Boolean           @default(false)
  approvedById   String?
  approvedByName String?
  approvedAt     DateTime?
  estimatedImpact Json?
  actorId        String?
  actorName      String?
  createdAt      DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

/// Entrada de costo. `nature` separa real / comprometido / forecast / potencial.
model CostEntry {
  id          String       @id @default(cuid())
  projectId   String
  category    CostCategory
  nature      CostNature   @default(ACTUAL)
  amount      Decimal      @db.Decimal(18, 4)
  currency    String       @default("USD")
  incurredOn  DateTime
  description String?
  billable    Boolean?
  personKey   String?      // identidad canónica (PersonIdentity.key) si aplica
  source      String       @default("manual") // manual | csv | jira | github | rate_calc
  sourceRef   String?
  createdById String?
  createdAt   DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, incurredOn])
  @@index([projectId, nature])
}

/// Entrada de ingreso / facturación. `type` distingue contratado, facturado,
/// cobrado, reconocido, pendiente, CR, bonus y penalidad.
model RevenueEntry {
  id          String      @id @default(cuid())
  projectId   String
  type        RevenueType
  amount      Decimal     @db.Decimal(18, 4)
  currency    String      @default("USD")
  date        DateTime
  description String?
  milestoneId String?
  source      String      @default("manual") // manual | csv | integration
  sourceRef   String?
  createdById String?
  createdAt   DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, date])
  @@index([projectId, type])
}

/// Tarifa/costo laboral CON vigencia histórica. Nunca se sobrescribe el pasado:
/// un cambio de tarifa crea un nuevo registro con effectiveFrom.
model LaborRate {
  id                  String    @id @default(cuid())
  projectId           String
  scope               RateScope @default(PERSON)
  key                 String    // personKey | rol | seniority | team | "*"
  internalCostPerHour Decimal?  @db.Decimal(18, 4)
  sellRatePerHour     Decimal?  @db.Decimal(18, 4)
  monthlyCost         Decimal?  @db.Decimal(18, 4)
  dailyCost           Decimal?  @db.Decimal(18, 4)
  allocationPct       Decimal?  @db.Decimal(9, 4)
  currency            String    @default("USD")
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  createdById         String?
  createdAt           DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, key, effectiveFrom])
}

/// Milestone económico (para modalidad Milestone Based y avance por hitos).
model FinanceMilestone {
  id                 String          @id @default(cuid())
  projectId          String
  name               String
  value              Decimal         @db.Decimal(18, 4)
  weight             Decimal?        @db.Decimal(9, 4) // peso para EV ponderado
  plannedDate        DateTime?
  actualDate         DateTime?
  status             MilestoneStatus @default(PLANNED)
  acceptanceCriteria String?
  retentionPct       Decimal?        @db.Decimal(9, 4)
  riskOfRejection    String?         // low | medium | high
  percentComplete    Decimal?        @db.Decimal(9, 4) // 0..100
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
